# JOB_AGENT_HOME=~/.job_agent
# JOB_AGENT_MIN_INTERVAL=2.0     # seconds between LLM calls (free-tier throttle)
# JOB_AGENT_MAX_RETRIES=5
# JOB_AGENT_HTTP_TIMEOUT=20
